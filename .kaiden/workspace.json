{
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "./features/chromium": {}
  },
  "mcp": {
    "commands": [
      {
        "name": "svelte",
        "command": "npx",
        "args": ["-y", "@sveltejs/mcp"]
      },
      {
        "name": "playwright",
        "command": "npx",
        "args": ["-y", "@playwright/mcp@latest"]
      }
    ]
  },
  "ports": [5173],
  "network": {
    "mode": "deny",
    "hosts": [
      "api.discogs.com",
      "registry.npmjs.org",
      "*.npmjs.org"
    ]
  }
}
